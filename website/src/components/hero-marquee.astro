---
const items = [
  "docker.ready",
  "caddy.routing",
  "postgres.backed-up",
  "redis.live",
  "logs.streaming",
  "domains.issued",
  "updates.available",
  "buildkit.warm",
];

const marqueeItems = [...items, ...items];
---

<div
  class="group absolute inset-x-0 bottom-0 z-[2] overflow-hidden border-t border-[rgba(52,56,67,0.9)] bg-[rgba(8,9,12,0.96)] py-[11px]"
  aria-label="Platform status ticker"
>
  <div
    class="flex w-max gap-10 pr-10 [animation:marquee_48s_linear_infinite] group-hover:[animation-play-state:paused] motion-reduce:animate-none motion-reduce:group-hover:[animation-play-state:running]"
  >
    {marqueeItems.map((item) => (
      <span class="shrink-0 font-mono text-[0.72rem] text-[#5f6370]">
        {item}
        <span aria-hidden="true" class="ml-10 text-[#30333b]">-</span>
      </span>
    ))}
  </div>
</div>

<style>
  @keyframes marquee {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }
</style>
