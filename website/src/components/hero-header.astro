<header
  class="flex items-center justify-between gap-[18px] pb-5 font-mono text-[0.72rem] text-(--aero-muted) max-[640px]:flex-col max-[640px]:items-start"
>
  <a class="inline-flex items-center gap-[11px] font-extrabold text-(--aero-text)" href="/">
    <span class="grid size-[30px] place-items-center border border-[rgba(79,184,178,0.36)] bg-[rgba(79,184,178,0.1)]">
      <img class="size-[17px]" src="/favicon.svg" alt="" />
    </span>
    <span>Aeroplane</span>
  </a>

  <div
    class="flex flex-wrap items-center justify-end gap-3 max-[640px]:justify-start"
    aria-label="System status"
  >
    <span class="relative flex size-[7px]" aria-hidden="true">
      <span class="absolute inline-flex size-full animate-ping rounded-full bg-(--aero-accent) motion-reduce:animate-none"></span>
      <span class="relative inline-flex size-[7px] rounded-full bg-(--aero-accent)"></span>
    </span>
    <span>control plane ready</span>
    <span aria-hidden="true">::</span>
    <a class="border-b border-current text-(--aero-text)" href="/docs/">docs</a>
    <span aria-hidden="true">::</span>
    <a
      class="border-b border-current text-(--aero-text)"
      data-analytics-event="github_link_clicked"
      data-analytics-placement="hero_header"
      href="https://github.com/xt42io/aeroplane"
    >
      source
    </a>
  </div>
</header>
