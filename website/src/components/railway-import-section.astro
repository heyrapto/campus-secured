---
import RailwayLogo from "./railway-logo.astro";
import RailwayImportVisual from "./railway-import-visual.astro";

const importSteps = [
  {
    label: "01",
    title: "Connect Railway",
    body: "Use a Railway personal API token to pull projects, environments, services, and deployment settings into view.",
  },
  {
    label: "02",
    title: "Choose what moves",
    body: "Pick the target environment and services, skip Railway-only variables, and decide whether databases should be recreated.",
  },
  {
    label: "03",
    title: "Land in Aeroplane",
    body: "Aeroplane creates the project, links app variables to new database credentials, imports custom domains where possible, and can queue deploys.",
  },
];

const importDetails = [
  "App variables and command overrides",
  "Postgres, MySQL, Redis, MongoDB, and Timescale services",
  "Database data imports for supported Postgres-family databases",
  "Custom domains and detected service ports",
];
---

<section class="relative overflow-hidden border-t border-[rgba(52,56,67,0.65)] bg-[#08090c] py-24 text-[var(--aero-text)]">
  <div
    class="pointer-events-none absolute inset-0 [background-image:linear-gradient(rgba(255,255,255,0.026)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.026)_1px,transparent_1px)] [background-size:72px_72px]"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-96 bg-[radial-gradient(ellipse_70%_50%_at_50%_0%,rgba(233,61,130,0.12),transparent)]"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto grid w-[min(1180px,calc(100%_-_40px))] gap-14 lg:grid-cols-[0.92fr_0.8fr] lg:items-start">
    <div>
      <h2 class="font-hero m-0 max-w-[13ch] text-[clamp(2.25rem,5vw,4.8rem)] font-bold leading-none text-zinc-100">
        Import from
        <span class="inline-flex items-center gap-[0.18em] whitespace-nowrap">
          Railway
          <RailwayLogo class="h-[0.8em] w-[0.8em] shrink-0 translate-y-[0.03em]" />
        </span>
      </h2>
      <p class="mt-6 max-w-xl font-mono text-sm leading-7 text-[var(--aero-muted)]">
        Move a Railway project into your self-hosted Aeroplane control plane without rebuilding the stack by hand.
        Services, variables, databases, and domains arrive as a project you can inspect and deploy.
      </p>

      <div class="mt-10 grid gap-3">
        {importSteps.map((step) => (
          <article class="grid gap-4 border border-[rgba(52,56,67,0.78)] bg-[rgba(17,19,24,0.5)] p-5 sm:grid-cols-[64px_1fr]">
            <div class="font-mono text-xs font-bold text-[#6d4158]">{step.label}</div>
            <div>
              <h3 class="m-0 text-xl font-semibold text-zinc-100">{step.title}</h3>
              <p class="mt-2 max-w-2xl font-mono text-[0.82rem] leading-6 text-[var(--aero-muted)]">{step.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="grid gap-5">
      <RailwayImportVisual />

      <div class="grid gap-2 border border-[rgba(52,56,67,0.78)] bg-[rgba(17,19,24,0.48)] p-5">
        <p class="m-0 font-mono text-[0.66rem] font-bold uppercase tracking-[0.2em] text-zinc-500">
          Included in the import
        </p>
        <div class="grid gap-2">
          {importDetails.map((detail) => (
            <div class="grid grid-cols-[auto_1fr] items-center gap-3 font-mono text-xs leading-6 text-zinc-300">
              <span class="size-1.5 bg-[var(--aero-accent)]"></span>
              <span>{detail}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
