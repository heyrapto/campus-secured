---
const features = [
  {
    title: "Git and URL deploys",
    body: "Deploy from connected GitHub repositories or paste a repository URL when you just want to move quickly.",
  },
  {
    title: "Generated domains",
    body: "Set a wildcard root domain and Aeroplane routes service hostnames through Caddy with HTTPS.",
  },
  {
    title: "Database cockpit",
    body: "Inspect Postgres, Redis, and MongoDB data from the same service pages you use for deployments.",
  },
  {
    title: "Updates built in",
    body: "Compare the running image commit against GitHub and update from the UI when a new image is available.",
  },
];
---

<section id="features" class="aero-container py-12">
  <div class="mb-8 max-w-2xl">
    <p class="text-sm font-bold text-[var(--aero-accent)]">FEATURES</p>
    <h2 class="mt-2 text-4xl font-black">The parts you keep reaching for.</h2>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    {features.map((feature) => (
      <article class="aero-panel p-6">
        <h3 class="text-xl font-black">{feature.title}</h3>
        <p class="mt-3 leading-7 text-[var(--aero-muted)]">{feature.body}</p>
      </article>
    ))}
  </div>
</section>
