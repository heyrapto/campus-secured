---
import Copy01Icon from "@hugeicons/core-free-icons/Copy01Icon";
import CopyCheckIcon from "@hugeicons/core-free-icons/CopyCheckIcon";

const command = "curl -fsSL https://get.aeroplane.run | sh";
const capabilities = ["apps", "postgres", "redis", "domains", "backups", "logs"];
const toPathAttrs = (icon) => icon.filter(([tag]) => tag === "path").map(([, attrs]) => ({
  d: attrs.d,
  stroke: attrs.stroke,
  "stroke-linecap": attrs.strokeLinecap,
  "stroke-linejoin": attrs.strokeLinejoin,
  "stroke-width": attrs.strokeWidth,
}));
const copyIconPaths = toPathAttrs(Copy01Icon);
const copiedIconPaths = toPathAttrs(CopyCheckIcon);

const previewLines = [
  ["resolve_preview", "app.example.com"],
  ["service_status", "api: active"],
  ["backup_window", "postgres: 02:00 UTC"],
];
---

<div
  class="grid gap-[18px] border border-[rgba(52,56,67,0.95)] bg-[rgba(8,9,12,0.68)] p-[clamp(20px,3vw,28px)] shadow-[0_0_60px_rgba(0,0,0,0.24)]"
>
  <p class="m-0 font-mono text-[0.67rem] font-extrabold uppercase text-[#5f6370]">Bootstrap node</p>

  <div
    class="grid min-h-[54px] grid-cols-[auto_minmax(0,1fr)_64px] items-center border border-[rgba(79,184,178,0.3)] bg-[rgba(17,19,24,0.82)] pl-3.5 font-mono text-[var(--aero-text)] max-[520px]:grid-cols-[auto_1fr] max-[520px]:p-3"
  >
    <span class="text-[var(--aero-accent)]" aria-hidden="true">&gt;</span>
    <code class="min-w-0 overflow-hidden text-ellipsis whitespace-nowrap px-[13px] text-[0.82rem] text-[var(--aero-text)]">
      {command}
    </code>
    <button
      aria-label="Copy install command"
      class="grid h-full min-h-[54px] w-full place-items-center border-l border-[rgba(52,56,67,0.9)] text-[var(--aero-accent)] transition hover:bg-[rgba(79,184,178,0.12)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--aero-accent)] max-[520px]:col-span-full max-[520px]:h-12 max-[520px]:min-h-0 max-[520px]:border-l-0 max-[520px]:border-t"
      data-copy-command={command}
      type="button"
    >
      <svg class="size-5 copy-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none">
        {copyIconPaths.map((attrs) => <path {...attrs} />)}
      </svg>
      <svg class="hidden size-5 copied-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none">
        {copiedIconPaths.map((attrs) => <path {...attrs} />)}
      </svg>
    </button>
  </div>

  <div>
    <p class="m-0 font-mono text-[0.67rem] font-extrabold uppercase text-[#5f6370]">Managed surface</p>
    <div class="mt-2.5 flex flex-wrap gap-2">
      {capabilities.map((capability) => (
        <span class="border border-[rgba(52,56,67,0.9)] bg-[rgba(8,9,12,0.78)] px-[9px] py-[7px] font-mono text-[0.76rem] text-[#c6c8ce]">
          [{capability}]
        </span>
      ))}
      <span class="border border-[rgba(79,184,178,0.5)] bg-[rgba(79,184,178,0.12)] px-[9px] py-[7px] font-mono text-[0.76rem] text-[var(--aero-accent)]">
        [+ more]
      </span>
    </div>
  </div>

  <div
    class="grid gap-[9px] border-t border-dashed border-[rgba(52,56,67,0.95)] pt-[18px] font-mono text-[0.78rem] text-[#c6c8ce]"
    aria-label="Deployment preview"
  >
    {previewLines.map(([label, value]) => (
      <p class="m-0 flex gap-2.5 max-[520px]:flex-col max-[520px]:gap-0.5">
        <span class="min-w-28 text-[#5f6370]">{label}</span>
        {value}
      </p>
    ))}
  </div>
</div>

<script>
  const copyButtons = document.querySelectorAll("[data-copy-command]");

  copyButtons.forEach((button) => {
    button.addEventListener("click", async () => {
      const command = button.getAttribute("data-copy-command") || "";

      try {
        await navigator.clipboard.writeText(command);
      } catch {
        const textarea = document.createElement("textarea");
        textarea.value = command;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.opacity = "0";
        document.body.append(textarea);
        textarea.select();
        document.execCommand("copy");
        textarea.remove();
      }

      button.setAttribute("aria-label", "Copied install command");
      button.setAttribute("data-copied", "true");
      window["posthog"]?.capture?.("install_command_copied", {
        placement: "hero_command_panel",
      });

      window.setTimeout(() => {
        button.setAttribute("aria-label", "Copy install command");
        button.removeAttribute("data-copied");
      }, 1400);
    });
  });
</script>

<style>
  [data-copy-command][data-copied] .copy-icon {
    display: none;
  }

  [data-copy-command][data-copied] .copied-icon {
    display: block;
  }
</style>
