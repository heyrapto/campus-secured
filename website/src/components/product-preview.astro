---
const services = [
  { name: "api", type: "APP", status: "ACTIVE" },
  { name: "postgres", type: "POSTGRES", status: "READY" },
  { name: "redis", type: "REDIS", status: "READY" },
];
---

<div class="aero-panel p-4 md:p-6">
  <div class="mb-5 flex items-center justify-between border-b border-[var(--aero-border)] pb-4">
    <div>
      <p class="text-xs font-bold text-[var(--aero-accent)]">AEROPLANE REGISTRY</p>
      <h2 class="mt-1 text-2xl font-black">Projects</h2>
    </div>
    <span class="border border-[var(--aero-border)] px-3 py-2 text-sm font-bold text-[var(--aero-muted)]">
      4/5 ready
    </span>
  </div>

  <div class="grid gap-3">
    {services.map((service) => (
      <div class="grid grid-cols-[1fr_auto_auto] items-center gap-3 border border-[var(--aero-border)] bg-[rgba(8,9,12,0.72)] p-4">
        <span class="font-bold">{service.name}</span>
        <span class="text-xs text-[var(--aero-muted)]">{service.type}</span>
        <span class="border border-[rgba(79,184,178,0.55)] px-3 py-1 text-xs font-bold text-[var(--aero-accent-strong)]">
          {service.status}
        </span>
      </div>
    ))}
  </div>

  <div class="mt-5 border border-[var(--aero-border)] bg-[#08090c] p-4 font-mono text-sm text-[var(--aero-muted)]">
    <p class="text-[var(--aero-accent-strong)]">$ curl -fsSL https://get.aeroplane.run | sh</p>
    <p class="mt-3">git: ok docker: ok buildkit: ok caddy: ok</p>
  </div>
</div>
